# =============================================================
# AI Product Manager Copilot — Environment Configuration (Example)
# =============================================================
# Rename this file to .env and fill in the values

DATABASE_URL=postgresql://postgres:9699@localhost:5432/ai_pm_copilot
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_pm_copilot
DB_USER=postgres
DB_PASSWORD=9699

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

FLASK_ENV=development
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=True

SECRET_KEY=generate-a-secure-256-bit-key-here
JWT_SECRET_KEY=generate-another-secure-256-bit-key-here

JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
JWT_ALGORITHM=HS256

FRONTEND_ORIGIN=http://localhost:5173

MAX_CSV_SIZE_MB=10
PIPELINE_AUTO_TRIGGER_THRESHOLD=5

SIMILARITY_THRESHOLD=0.85
NLP_MODEL=en_core_web_sm
EMBEDDING_MODEL=all-MiniLM-L6-v2
PIPELINE_VERSION=1.0.0

LOG_LEVEL=DEBUG
LOG_TO_FILE=False
LOG_FILE_PATH=logs/app.log
