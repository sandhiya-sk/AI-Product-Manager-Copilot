# =============================================================
# AI Product Manager Copilot — Environment Configuration
# =============================================================
# Copy this file to .env and fill in all values before running
# NEVER commit the actual .env file to version control
# Add .env to your .gitignore
# =============================================================


# -------------------------------------------------------------
# POSTGRESQL DATABASE CONFIGURATION
# -------------------------------------------------------------

# Full PostgreSQL connection string (used by SQLAlchemy)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:9699@localhost:5432/ai_pm_copilot

# Individual database connection parameters
# (used if you prefer to build the connection string in code)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_pm_copilot
DB_USER=postgres
DB_PASSWORD=9699

# Connection pool settings (SQLAlchemy)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800


# -------------------------------------------------------------
# FLASK APPLICATION SETTINGS
# -------------------------------------------------------------

FLASK_ENV=development
# Options: development | production | testing

FLASK_PORT=5000
FLASK_HOST=0.0.0.0

FLASK_DEBUG=True
# Set to False in production

SECRET_KEY=change-this-to-a-random-256-bit-secret-key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"


# -------------------------------------------------------------
# JWT AUTHENTICATION SETTINGS
# -------------------------------------------------------------

JWT_SECRET_KEY=change-this-to-another-random-256-bit-secret
# Must be different from SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
# How long access tokens remain valid (in hours)

JWT_ALGORITHM=HS256
# HMAC SHA-256 signing algorithm


# -------------------------------------------------------------
# FRONTEND / CORS SETTINGS
# -------------------------------------------------------------

FRONTEND_ORIGIN=http://localhost:5173
# React Vite dev server runs on port 5173 by default
# Update to your production URL when deploying


# -------------------------------------------------------------
# MODULE 2 — DATA INGESTION SETTINGS
# -------------------------------------------------------------

MAX_CSV_SIZE_MB=10
# Maximum allowed CSV file size in megabytes

PIPELINE_AUTO_TRIGGER_THRESHOLD=5
# Number of pending records that triggers automatic pipeline run


# -------------------------------------------------------------
# MODULE 3 — NLP PIPELINE SETTINGS
# -------------------------------------------------------------

SIMILARITY_THRESHOLD=0.85
# Cosine similarity threshold for semantic duplicate detection
# Range: 0.0 to 1.0 (higher = stricter matching)
# Recommended: 0.80 – 0.90

NLP_MODEL=en_core_web_sm
# spaCy model to use for lemmatization
# Options: en_core_web_sm | en_core_web_md | en_core_web_lg
# Install with: python -m spacy download en_core_web_sm

EMBEDDING_MODEL=all-MiniLM-L6-v2
# sentence-transformers model for semantic embeddings
# Downloaded automatically on first use from HuggingFace

PIPELINE_VERSION=1.0.0
# Version tag stored in processing_metadata JSONB


# -------------------------------------------------------------
# LOGGING
# -------------------------------------------------------------

LOG_LEVEL=DEBUG
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL

LOG_TO_FILE=False
LOG_FILE_PATH=logs/app.log
